# Wealth Tracker - Environment Configuration
#
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is git-ignored and is where your real credentials go.
# Vite loads it automatically in both dev and production builds.
#
# If you use separate Google OAuth apps for dev vs prod (recommended),
# set the variables per deploy context in your hosting platform instead.

# Google OAuth Client ID (Web application type)
# Get one from: Google Cloud Console > APIs & Services > Credentials
# Required scopes: drive.appdata
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Environment mode: DEVELOPMENT or PRODUCTION
# DEVELOPMENT shows a warning banner and prefixes the page title with [DEV].
# PRODUCTION shows nothing.
VITE_APP_ENV=DEVELOPMENT
