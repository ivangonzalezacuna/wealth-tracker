# Copy this file to .env.local and fill in your values
# .env.local is git-ignored and never committed

VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
VITE_GOOGLE_SHEET_ID=your-sheet-id-here
# API key restricted to the Google Picker API (Console: APIs & Services >
# Credentials > Create Credentials > API key; restrict by HTTP referrer to
# your domains, and by API to "Google Picker API" only). Required for the
# one-time drive.file authorization flow in src/auth/picker.ts.
VITE_GOOGLE_PICKER_API_KEY=your-picker-api-key-here
