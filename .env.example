# Environment configuration reference.
#
# The app uses separate .env.development and .env.production files (committed)
# for environment-specific settings. Use .env.local (git-ignored) only for
# secret overrides that should never be committed.
#
# Each environment uses a SEPARATE Google OAuth application, which means
# Drive AppData storage is fully isolated between dev and prod.

# Google OAuth Client ID (one per environment - see .env.development / .env.production)
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Environment label (DEVELOPMENT or PRODUCTION) - controls the visual indicator
VITE_ENV_LABEL=DEVELOPMENT
